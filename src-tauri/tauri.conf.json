{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DB Studio",
  "version": "0.1.5",
  "identifier": "com.kidchang.dbstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DB Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kidchang93/db-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENEOTNDMkY4OEQ4NTE4M0IKUldRN0dJV04rTUtUelVCa2NVUWVuLzJMbHVlRWZSQXZNODlVbDl0aWs1bUpPR2lhdjBpWXY2YzgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "shortDescription": "다중 DB 클라이언트 (PostgreSQL / MySQL / SQLite / SQL Server)",
    "longDescription": "DataGrip 스타일의 직관적인 크로스플랫폼 데이터베이스 클라이언트. 스키마 탐색, 데이터 그리드 인라인 CRUD, SQL 에디터를 지원합니다.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
